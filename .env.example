NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000
YOUTUBE_API_KEY=
MAX_VIDEO_DURATION_SECONDS=600
TEMP_FILE_TTL_MINUTES=30
TEMP_DIR=/tmp/neptune
MAX_CONCURRENT_JOBS=2
JOB_TIMEOUT_SECONDS=900
DOWNLOAD_BASE_URL=
LOG_LEVEL=info

# Optional: longer values improve stability for some tracks, lower values are faster.
AUDIO_ANALYSIS_SAMPLE_SECONDS=180

# Optional tool overrides. Leave these commented out on Windows unless you know
# the exact paths. neptune can use `py -m yt_dlp`, the bundled ffmpeg package,
# and `py` automatically.
# YT_DLP_BIN=yt-dlp
# FFMPEG_BIN=ffmpeg
# PYTHON_BIN=python
# YT_DLP_JS_RUNTIME=node:C:\path\to\node.exe
